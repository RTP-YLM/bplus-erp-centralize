# Copy to .env and fill in real values

# Supabase REST API (primary - uses HTTPS, works on Railway)
# These use the REST API endpoint which works over IPv4
SUPABASE_URL=https://xbgfiengqwcsdxrnvbbk.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# Supabase PostgreSQL (fallback for SQL execution)
# password อยู่ที่ Supabase Dashboard → Settings → Database → Connection string
# NOTE: Direct PostgreSQL connection may not work on Railway due to IPv6
PG_DSN=postgresql://postgres:[YOUR-PASSWORD]@db.xbgfiengqwcsdxrnvbbk.supabase.co:5432/postgres

# Anthropic API (for Claude chatbot)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Claude model selection (default: claude-haiku-4-5)
CLAUDE_MODEL=claude-haiku-4-5

# LINE Official Account
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_DESTINATION_USER_ID=Ub5928af25c0550217c9ec9d828f51f98
